/*
 * Configurable Variables
 * Update these variables with desired units, vehicles, etc. to be used within the missions
 *
 * Variable names can be retrieve from the ingame editor, hovering over the desired item and
 * appearing under the readable name
 *
 * Example:
 * Updating CAS -> vehicle to "B_Plane_CAS_01_dynamicLoadout_F" will spawn an A164 Wipeout (CAS) as CAS support
*/
class CfgVariables {
    class Support {
        class CloseAirSupport {
            vehicle = "CUP_B_A10_DYN_USA"; // CUP - USArmy - A10A Thunderbolt II
            attackType = 0; // Options: 0 - Guns Run, 1 - Missiles Strike, 2 - Guns and Missiles, 3 - Bomb Strike
            cooldown = 300; // 5 minutes (300 / 60)
        };
        // class Artillery {};
    };
    class Squads {
        class Infantry { // Update with Blufor and Opfor options
            rifle[] = {
                "CUP_O_RU_Soldier_SL_M_EMR_V2", // Squad Leader
                "CUP_O_RU_Soldier_TL_M_EMR_V2", // Team Leader
                "CUP_O_RU_Soldier_AR_M_EMR_V2", // Automatic Rifleman
                "CUP_O_RU_Soldier_GL_EMR_V2", // Grenadier
                "CUP_O_RU_Soldier_A_M_EMR_V2", // Ammo Bearer
                "CUP_O_RU_Soldier_Medic_M_EMR_V2", // Medic
                "CUP_O_RU_Soldier_LAT_M_EMR_V2", // Missile Specialist (AT)
                "CUP_O_RU_Soldier_M_EMR_V2", // Rifleman
                "CUP_O_RU_Soldier_MG_M_EMR_V2", // Heavy Gunner (Machine Gunner)
            };
        };
    };
    class Units {
        class Motorised {
            //standard = "O_MRAP_02_hmg_F";
            standard = "CUP_O_UAZ_MG_RU"; // CUP - UAZ-496 (DShKM)
        };
        transport = "CUP_O_Ural_Open_RU";
    };
    class Misc {
        class Debug {
            enabled = true; // Enables debug mode
            enableSpawnZoneMarkers = true; // Creates markers to visualise spawn zones with markers
            enableBlockadeMarkers = true; // Creates markers to visualise blockade trigger ranges
            runTestsOnStart = true; // Runs scripts/tests/fn_runTests.sqf at startup when true
            enableInvincibleConfiguredGroup = true; // If true and debug enabled, configured group stays invincible
            invincibleGroupVarName = "blufor_group"; // Variable name that resolves to a group or a unit in that group
        };
        class Blacklist {
            mods[] = {
                "PA_arsenal",
                "DCONVirtualGarage"
            };
            prefixes[] = {};
        };
    };
    /*
     * Dynamic Occupation Variables
     * Each of these variables control how the dynamic occupation system functions.
     * Adjusting these variables will change how the system behaves in terms of:
     *   spawn location
     *   frequency
     *   density
     *
     * Each variable is measured in meters.
     *
     * Feel free to adjust these values to your liking,
     * but it is recommended to leave them alone to avoid breaking the balance of the system.
     * 
     */
    class Dynamic {
        class AreaOccupation {
            activationDistance = 80;
            minSpawnDistance = 50;
            minSpawnDistanceFloor = 40;
            spawnZoneSize = 60;
            aliveUnitCap = 120;

            // Blockades can be seen from farther out, so these multipliers allow earlier spawn.
            blockadeSpawnDistanceMultiplier = 3.1;
            blockadeLOSProbeDistanceMultiplier = 4.5;
            blockadeSpawnDistanceMin = 340;
            blockadeLOSProbeDistanceMin = 580;
        };
    };
};

/* ---------- DO NOT CHANGE ---------- */
respawnOnStart = 0;

