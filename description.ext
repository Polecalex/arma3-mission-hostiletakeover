class RscTitles {
    class HT_ActiveUnitsHUD {
        idd = -1;
        movingEnable = 0;
        duration = 1e+011;
        fadeIn = 0;
        fadeOut = 0;
        onLoad = "uiNamespace setVariable ['HT_ActiveUnitsHUD', _this select 0];";

        class controls {
            class ActiveUnitsText {
                idc = 91001;
                type = 13;
                style = 0;
                x = "safeZoneX + safeZoneW - 0.292";
                y = "safeZoneY + safeZoneH - 0.095";
                w = 0.28;
                h = 0.07;
                size = 0.035;
                colorBackground[] = {0, 0, 0, 0.25};
                text = "";

                class Attributes {
                    font = "PuristaMedium";
                    color = "#FFFFFF";
                    align = "right";
                    shadow = 1;
                };
            };
        };
    };
};
